<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controller.LoginController"
           stylesheets="@../styles/style.css"
           style="-fx-background-color: #080c14;">

    <!-- Fond décoratif avec dégradé radial -->
    <Pane style="-fx-background-color: radial-gradient(center 50% 30%, radius 80%, #1a1f3c 0%, #080c14 100%);"/>

    <!-- Carte de connexion centrée -->
    <VBox alignment="CENTER" spacing="0" maxWidth="440">

        <!-- Logo & Titre -->
        <VBox alignment="CENTER" spacing="8">
            <padding><Insets top="0" bottom="32"/></padding>
            <Label text="🎓" style="-fx-font-size: 56px;"/>
            <Label text="PlanifyEdu"
                   style="-fx-text-fill: #ffffff; -fx-font-size: 32px; -fx-font-weight: bold;
                          -fx-effect: dropshadow(gaussian, #6366f1, 16, 0.4, 0, 0);"/>
            <Label text="Système de gestion de planification universitaire"
                   style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
        </VBox>

        <!-- Panneau du formulaire -->
        <VBox styleClass="form-card" spacing="20" style="-fx-padding: 36; -fx-background-radius: 16; -fx-border-radius: 16;">

            <!-- Titre du formulaire -->
            <Label text="Connexion" style="-fx-text-fill: #e2e8f0; -fx-font-size: 20px; -fx-font-weight: bold;"/>

            <!-- Message d'erreur (masqué par défaut) -->
            <Label fx:id="labelErreur" text=""
                   style="-fx-text-fill: #ef4444; -fx-font-size: 12px; -fx-wrap-text: true;"
                   visible="false" managed="false"/>

            <!-- Champ login -->
            <VBox spacing="6">
                <Label text="Identifiant" styleClass="field-label"/>
                <TextField fx:id="fieldLogin"
                           promptText="admin / prof / etudiant"
                           styleClass="form-input"
                           onKeyPressed="#onKeyPressed"/>
            </VBox>

            <!-- Champ mot de passe -->
            <VBox spacing="6">
                <Label text="Mot de passe" styleClass="field-label"/>
                <PasswordField fx:id="fieldPassword"
                               promptText="Entrez votre mot de passe"
                               styleClass="form-input"
                               onKeyPressed="#onKeyPressed"/>
            </VBox>

            <!-- Bouton connexion -->
            <Button fx:id="btnConnexion"
                    text="🔐  Se connecter"
                    styleClass="btn-primary"
                    onAction="#seConnecter"
                    maxWidth="Infinity"
                    style="-fx-font-size: 14px; -fx-padding: 12 24 12 24;"/>

            <!-- Séparateur -->
            <Separator style="-fx-background-color: #2d3748;"/>

            <!-- Aide comptes de démonstration -->
            <VBox spacing="6" style="-fx-background-color: rgba(99,102,241,0.08); -fx-background-radius: 8; -fx-padding: 12;">
                <Label text="💡 Comptes de démonstration :"
                       style="-fx-text-fill: #6366f1; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Label text="admin / admin123   →  Administrateur (accès total)"
                       style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-family: monospace;"/>
                <Label text="prof / prof123          →  Enseignant (lecture seule)"
                       style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-family: monospace;"/>
                <Label text="etudiant / etud123  →  Étudiant (consultation)"
                       style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-family: monospace;"/>
            </VBox>
        </VBox>

        <!-- Version -->
        <Label text="PlanifyEdu v1.0  ·  © 2025 Université"
               style="-fx-text-fill: #374151; -fx-font-size: 11px; -fx-padding: 20 0 0 0;"/>

    </VBox>

</StackPane>
